generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USER SECTION //

// Defines user roles in the system
enum UserRole {
  ADMIN
  COUNSELOR
}

// User table (Admin & Counselors)
model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  password     String
  role         UserRole       @default(COUNSELOR)
  isVerified   Boolean        @default(false)
  leads        Lead[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  LeadActivity LeadActivity[]
}


// Lead stages (Pipeline columns)
enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  LOST
}

// Source of the lead (for analytics & marketing tracking)
enum LeadSource {
  INSTAGRAM
  WEBSITE
  WALK_IN
  GOOGLE_ADS
  META_ADS
  REFERRAL
}

// Priority level for counselor attention
enum LeadPriority {
  HOT
  WARM
  COLD
}
// Lost lead reasons
enum LostReason {
  NO_RESPONSE
  NOT_INTERESTED
  FINANCIAL_ISSUE
  CHOSE_OTHER_CONSULTANT
  NOT_ELIGIBLE
  DUPLICATE_LEAD
  OTHER
}

model LeadNote {
  id        String   @id @default(uuid())
  content   String
  leadId    String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// LEAD MODEL //
model Lead {
  id String @id @default(uuid())

  // Personal Info
  fullName   String
  phone      String  @unique
  email      String?
  country    String
  ieltsScore Float?

  // Classification Details
  status   LeadStatus   @default(NEW)
  source   LeadSource
  priority LeadPriority @default(WARM)

  // Assignment & Follow-up
  counselorId  String?
  counselor    User?     @relation(fields: [counselorId], references: [id])
  followUpDate DateTime?


  // Lost reason 
  lostReason   LostReason?

  // Relations
  notes      LeadNote[]
  activities LeadActivity[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([country])
  @@index([counselorId])
  @@index([followUpDate])
  @@index([createdAt])
  @@index([lostReason])
}

// Lead Activity Timeline
model LeadActivity {
  id        String       @id @default(uuid())
  type      ActivityType
  message   String
  meta      Json?
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id])
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  STATUS_CHANGE
  EDIT
}

// OTP Verification
model OtpVerification {
  id        String    @id @default(uuid())
  email     String
  otp       String
  name      String    @default("")  
  password  String    @default("")   
  role      UserRole  @default(COUNSELOR)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([email])
}


// Password Reset
model PasswordReset {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}


// Email Templates
model EmailTemplate {
  id         String   @id @default(uuid())
  name       String
  subject    String
  content    String
  attachment String? 
  createdAt  DateTime @default(now())
}




