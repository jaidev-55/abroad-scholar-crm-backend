generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// USER SECTION //

// Defines user roles in the system
enum UserRole {
  ADMIN
  COUNSELOR
}

// User table (Admin & Counselors)
model User {
  id         String         @id @default(uuid())
  name       String
  email      String         @unique
  password   String
  role       UserRole       @default(COUNSELOR)
  leads      Lead[]
  activities LeadActivity[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// LEAD ENUMS (Fixed Pipeline Version)

// Lead stages (Pipeline columns)
enum LeadStatus {
  NEW
  IN_PROGRESS
  CONVERTED
  LOST
}

// Source of the lead (for analytics & marketing tracking)
enum LeadSource {
  INSTAGRAM
  WEBSITE
  WALK_IN
  GOOGLE_ADS
  META_ADS
  REFERRAL
}

// Priority level for counselor attention
enum LeadPriority {
  HOT
  WARM
  COLD
}

model LeadNote {
  id        String   @id @default(uuid())
  content   String
  leadId    String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// LEAD MODEL //
model Lead {
  id String @id @default(uuid())

  // Personal Info
  fullName   String
  phone      String  @unique
  email      String?
  country    String
  ieltsScore Float?

  // Classification Details
  status   LeadStatus   @default(NEW)
  source   LeadSource
  priority LeadPriority @default(WARM)

  // Assignment & Follow-up
  counselorId  String?
  counselor    User?     @relation(fields: [counselorId], references: [id])
  followUpDate DateTime?
  lostReason   String?

  notes LeadNote[]

  // Timestamps 
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  LeadActivity LeadActivity[]

  // Indexes
  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([country])
  @@index([counselorId])
  @@index([followUpDate])
  @@index([createdAt])


}

// Leads Activity
model LeadActivity {
  id        String       @id @default(uuid())
  type      ActivityType
  message   String
  meta      Json?
  lead      Lead         @relation(fields: [leadId], references: [id])
  leadId    String
  user      User?        @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime     @default(now())
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  STATUS_CHANGE
  EDIT
}
