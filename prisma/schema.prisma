generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider= "postgresql"
  url = env("DATABASE_URL")
}


enum UserRole {
  ADMIN
  COUNSELOR
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  role UserRole @default(COUNSELOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}